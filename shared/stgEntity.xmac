#ifndef ENTITY
#define ENTITY(name, fields)
#define FIELD(type, name, ...)
#endif




ENTITY(bezierEnemy,
	FIELD(s16, x)
	FIELD(s16, y)
	FIELD(s16, pattern, 0)
	FIELD(s32, duration, 5000)
)

ENTITY(enemyStraight,
	FIELD(s16, x)
	FIELD(s16, y)
	FIELD(s16, vx)
	FIELD(s16, vy)
)



#undef ENTITY
#undef FIELD
